@model List<AdminResultMovieDto>
@{
    ViewData["Title"] = "Film Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
rel="stylesheet">

<style>
    :root {
        --bg: #eef0f7;
        --surface: #ffffff;
        --surface2: #f5f6fb;
        --border: rgba(30, 40, 100, 0.08);
        --border-h: rgba(30, 40, 100, 0.16);
        --accent: #5b4ef8;
        --accent-dim: rgba(91, 78, 248, 0.09);
        --accent-glow: rgba(91, 78, 248, 0.2);
        --gold: #b07400;
        --gold-dim: rgba(176, 116, 0, 0.09);
        --green: #0a9060;
        --green-dim: rgba(10, 144, 96, 0.09);
        --red: #cc3333;
        --red-dim: rgba(204, 51, 51, 0.08);
        --amber: #a86000;
        --amber-dim: rgba(168, 96, 0, 0.09);
        --text: #181830;
        --text-2: #52527a;
        --text-3: #9898b8;
        --radius: 10px;
        --row-h: 58px;
    }

    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .mv {
        font-family: 'Outfit', sans-serif;
        background: var(--bg);
        min-height: 100vh;
        padding: 1.5rem 1.5rem 3rem;
        color: var(--text);
    }

    /* ── TOP BAR ── */
    .mv-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }

    .mv-breadcrumb {
        font-size: 0.75rem;
        color: var(--text-3);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-weight: 500;
        margin-bottom: 0.2rem;
    }

    .mv-heading {
        font-size: 1.45rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: var(--text);
        line-height: 1;
    }

    .mv-pill {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        font-weight: 500;
        color: var(--accent);
        background: var(--accent-dim);
        border: 1px solid rgba(91, 78, 248, 0.22);
        padding: 0.2rem 0.55rem;
        border-radius: 6px;
        align-self: flex-end;
        margin-bottom: 2px;
    }

    .mv-spacer {
        flex: 1;
    }

    .mv-toolbar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .mv-search {
        position: relative;
        display: flex;
        align-items: center;
    }

    .mv-search svg {
        position: absolute;
        left: 0.75rem;
        color: var(--text-3);
        width: 14px;
        height: 14px;
        pointer-events: none;
    }

    .mv-search input {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0.9rem 0.5rem 2.25rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.825rem;
        color: var(--text);
        width: 210px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s, width 0.25s;
    }

    .mv-search input::placeholder {
        color: var(--text-3);
    }

    .mv-search input:focus {
        border-color: rgba(91, 78, 248, 0.4);
        box-shadow: 0 0 0 3px var(--accent-glow);
        width: 270px;
    }

    .mv-filter-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0.85rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-2);
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
    }

    .mv-filter-btn svg {
        width: 13px;
        height: 13px;
    }

    .mv-filter-btn:hover {
        border-color: var(--border-h);
        color: var(--text);
    }

    /* ── SHELL ── */
    .mv-shell {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }

    .mv-shell::before {
        content: '';
        position: absolute;
        inset: 0 0 auto 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, var(--accent) 40%, rgba(91, 78, 248, 0.3) 70%, transparent 100%);
        opacity: 0.5;
    }

    /* ── TABLE ── */
    .mv-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: auto;
    }

    .mv-table thead th {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-3);
        padding: 0 0.75rem;
        height: 40px;
        text-align: left;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
        white-space: nowrap;
    }

    .mv-table thead th:first-child {
        padding-left: 1.25rem;
    }

    .mv-table thead th:last-child {
        padding-right: 1.25rem;
    }

    th.sortable {
        cursor: pointer;
        user-select: none;
    }

    th.sortable:hover {
        color: var(--text-2);
    }

    th.sortable svg {
        width: 10px;
        height: 10px;
        display: inline;
        margin-left: 4px;
        vertical-align: middle;
    }

    /* rows */
    .mv-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
        opacity: 0;
        animation: fadeRow 0.35s ease forwards;
    }

    @@keyframes fadeRow {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .mv-table tbody tr:last-child {
        border-bottom: none;
    }

    .mv-table tbody tr:hover {
        background: rgba(91, 78, 248, 0.035);
    }

    .mv-table tbody tr:nth-child(1) {
        animation-delay: 0.03s;
    }

    .mv-table tbody tr:nth-child(2) {
        animation-delay: 0.06s;
    }

    .mv-table tbody tr:nth-child(3) {
        animation-delay: 0.09s;
    }

    .mv-table tbody tr:nth-child(4) {
        animation-delay: 0.12s;
    }

    .mv-table tbody tr:nth-child(5) {
        animation-delay: 0.15s;
    }

    .mv-table tbody tr:nth-child(6) {
        animation-delay: 0.18s;
    }

    .mv-table tbody tr:nth-child(7) {
        animation-delay: 0.21s;
    }

    .mv-table tbody tr:nth-child(8) {
        animation-delay: 0.24s;
    }

    .mv-table tbody tr:nth-child(9) {
        animation-delay: 0.27s;
    }

    .mv-table tbody tr:nth-child(10) {
        animation-delay: 0.30s;
    }

    .mv-table tbody td {
        padding: 0 0.75rem;
        height: var(--row-h);
        font-size: 0.875rem;
        color: var(--text);
        vertical-align: middle;
        white-space: nowrap;
    }

    .mv-table tbody td:first-child {
        padding-left: 1.25rem;
    }

    .mv-table tbody td:last-child {
        padding-right: 1.25rem;
    }

    /* ── CELLS ── */

    /* sıra no */
    .mv-id {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-3);
    }

    /* film adı + mini poster */
    .mv-film-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        min-width: 0;
    }

    .mv-poster {
        width: 30px;
        height: 42px;
        border-radius: 5px;
        object-fit: cover;
        background: var(--surface2);
        border: 1px solid var(--border);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .mv-poster img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .mv-poster-placeholder {
        width: 30px;
        height: 42px;
        border-radius: 5px;
        background: var(--surface2);
        border: 1px solid var(--border);
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-3);
    }

    .mv-poster-placeholder svg {
        width: 14px;
        height: 14px;
    }

    .mv-film-info {
        min-width: 0;
    }

    .mv-name {
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: -0.01em;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block;
        max-width: 160px;
    }

    /* kategori badge — renkli */
    .mv-cat-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.18rem 0.55rem;
        border-radius: 5px;
        margin-top: 0.2rem;
        letter-spacing: 0.02em;
    }

    .mv-cat-badge::before {
        content: '';
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    /* rating */
    .mv-rating {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--gold);
        background: var(--gold-dim);
        padding: 0.25rem 0.65rem;
        border-radius: 6px;
        border: 1px solid rgba(176, 116, 0, 0.15);
    }

    .mv-rating svg {
        width: 10px;
        height: 10px;
        fill: var(--gold);
        flex-shrink: 0;
    }

    /* yıl */
    .mv-year {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: var(--text-2);
    }

    /* durum */
    .mv-status {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 0.25rem 0.65rem;
        border-radius: 100px;
    }

    .mv-status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    .mv-status.on {
        color: var(--green);
        background: var(--green-dim);
        border: 1px solid rgba(10, 144, 96, 0.2);
    }

    .mv-status.off {
        color: var(--red);
        background: var(--red-dim);
        border: 1px solid rgba(204, 51, 51, 0.2);
    }

    /* ── ACTIONS ── */
    .mv-actions {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 0.25rem;
        flex-wrap: nowrap;
    }

    .mv-icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.28rem;
        height: 28px;
        padding: 0 0.6rem;
        border-radius: 7px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--text-3);
        cursor: pointer;
        text-decoration: none;
        font-family: 'Outfit', sans-serif;
        font-size: 0.73rem;
        font-weight: 500;
        white-space: nowrap;
        transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
        flex-shrink: 0;
    }

    .mv-icon-btn svg {
        width: 13px;
        height: 13px;
    }

    .mv-icon-btn:hover {
        transform: translateY(-1px);
    }

    .mv-icon-btn.det:hover {
        background: var(--accent-dim);
        border-color: rgba(91, 78, 248, 0.22);
        color: var(--accent);
    }

    .mv-icon-btn.upd:hover {
        background: var(--amber-dim);
        border-color: rgba(168, 96, 0, 0.2);
        color: var(--amber);
    }

    .mv-icon-btn.del:hover {
        background: var(--red-dim);
        border-color: rgba(204, 51, 51, 0.2);
        color: var(--red);
    }

    .mv-actions-sep {
        width: 1px;
        height: 16px;
        background: var(--border);
        flex-shrink: 0;
        margin: 0 0.1rem;
    }

    /* ── FOOTER ── */
    .mv-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--surface2);
    }

    .mv-footer-info {
        font-size: 0.78rem;
        color: var(--text-3);
    }

    .mv-footer-info strong {
        color: var(--text-2);
        font-weight: 600;
    }

    .mv-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.55rem 1.1rem;
        border-radius: 10px;
        background: var(--accent);
        color: #fff;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
        box-shadow: 0 4px 16px var(--accent-glow);
    }

    .mv-add-btn svg {
        width: 14px;
        height: 14px;
    }

    .mv-add-btn:hover {
        background: #7c6dfa;
        box-shadow: 0 6px 22px rgba(91, 78, 248, 0.35);
        transform: translateY(-1px);
    }

    /* ── EMPTY ── */
    .mv-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-3);
    }

    .mv-empty svg {
        width: 40px;
        height: 40px;
        margin-bottom: 0.75rem;
        opacity: 0.25;
    }

    .mv-empty p {
        font-size: 0.875rem;
    }
</style>

<div class="mv">

    <div class="mv-top">
        <div>
            <div class="mv-breadcrumb">Admin / Filmler</div>
            <div style="display:flex;align-items:baseline;gap:0.6rem">
                <h1 class="mv-heading">Film Listesi</h1>
                <span class="mv-pill">@Model.Count kayıt</span>
            </div>
        </div>

        <div class="mv-spacer"></div>

        <div class="mv-toolbar">
            <div class="mv-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                <input type="text" id="mvSearch" placeholder="Film veya kategori ara…" autocomplete="off">
            </div>

            <button class="mv-filter-btn" id="mvFilterBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round">
                    <line x1="4" y1="6" x2="20" y2="6" />
                    <line x1="8" y1="12" x2="16" y2="12" />
                    <line x1="11" y1="18" x2="13" y2="18" />
                </svg>
                Filtrele
            </button>
        </div>
    </div>

    <div class="mv-shell">
        <div style="overflow-x:auto">
            <table class="mv-table" id="mvTable">
                <thead>
                    <tr>
                        <th style="width:44px">#</th>
                        <th class="sortable" data-col="1" style="min-width:190px">
                            Film Adı
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M7 15l5 5 5-5" />
                                <path d="M7 9l5-5 5 5" />
                            </svg>
                        </th>
                        <th class="sortable" data-col="2" style="width:110px">
                            Rating
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M7 15l5 5 5-5" />
                                <path d="M7 9l5-5 5 5" />
                            </svg>
                        </th>
                        <th class="sortable" data-col="3" style="width:75px">
                            Yıl
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M7 15l5 5 5-5" />
                                <path d="M7 9l5-5 5 5" />
                            </svg>
                        </th>
                        <th style="width:90px">Durum</th>
                        <th style="width:200px">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="mvBody">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td><span class="mv-id">@count</span></td>

                                <td>
                                    <div class="mv-film-cell">
                                        @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                                        {
                                            <div class="mv-poster">
                                                <img src="@item.CoverImageUrl" alt="@item.Title" loading="lazy"
                                                     onerror="this.parentElement.innerHTML='<svg viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'1.5\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg>'" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mv-poster-placeholder">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                                    <rect x="3" y="3" width="18" height="18" rx="2" />
                                                    <circle cx="8.5" cy="8.5" r="1.5" />
                                                    <polyline points="21 15 16 10 5 21" />
                                                </svg>
                                            </div>
                                        }
                                        <div class="mv-film-info">
                                            <span class="mv-name" title="@item.Title">@item.Title</span>
                                            @if (!string.IsNullOrEmpty(item.CategoryName))
                                            {
                                                <span class="mv-cat-badge" data-cat="@item.CategoryName">@item.CategoryName</span>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="mv-rating">
                                        <svg viewBox="0 0 24 24">
                                            <path
                                            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                        </svg>
                                        @item.Rating
                                    </span>
                                </td>

                                <td><span class="mv-year">@item.CreatedYear</span></td>

                                <td>
                                    @if (item.Status == true)
                                    {
                                        <span class="mv-status on"><span class="mv-status-dot"></span>Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="mv-status off"><span class="mv-status-dot"></span>Pasif</span>
                                    }
                                </td>

                                <td>
                                    <div class="mv-actions">
                                        <a href="/Admin/AdminMovie/DetailsMovie?id=@item.MovieId" class="mv-icon-btn det">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                <circle cx="12" cy="12" r="3" />
                                            </svg>
                                            Detay
                                        </a>
                                        <a href="/Admin/AdminMovie/UpdateMovie?id=@item.MovieId" class="mv-icon-btn upd">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                            Düzenle
                                        </a>
                                        <span class="mv-actions-sep"></span>
                                        <a href="/Admin/AdminMovie/DeleteMovie/@item.MovieId" class="mv-icon-btn del">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                 stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6l-1 14H6L5 6" />
                                                <path d="M10 11v6M14 11v6" />
                                                <path d="M9 6V4h6v2" />
                                            </svg>
                                            Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="mv-empty">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <rect x="2" y="4" width="20" height="16" rx="2" />
                                        <path d="M10 9l5 3-5 3V9z" />
                                    </svg>
                                    <p>Henüz film eklenmemiş.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mv-footer">
            <span class="mv-footer-info">Toplam <strong>@Model.Count</strong> film &nbsp;·&nbsp; <span
                id="mvVisible">@Model.Count</span> gösteriliyor</span>
                <a href="/Admin/AdminMovie/CreateMovie" class="mv-add-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path d="M12 5v14M5 12h14" />
                    </svg>
                    Yeni Film Ekle
                </a>
            </div>
        </div>
    </div>

    <script>
        (function () {
            // ── Kategori badge renkleri ──
            const catPalette = [
                { bg: 'rgba(91,78,248,0.09)', color: '#5b4ef8' },
                { bg: 'rgba(10,144,96,0.1)', color: '#0a9060' },
                { bg: 'rgba(176,116,0,0.1)', color: '#b07400' },
                { bg: 'rgba(204,51,51,0.08)', color: '#cc3333' },
                { bg: 'rgba(37,99,235,0.09)', color: '#2563eb' },
                { bg: 'rgba(124,58,237,0.09)', color: '#7c3aed' },
                { bg: 'rgba(8,145,178,0.09)', color: '#0891b2' },
                { bg: 'rgba(180,83,9,0.09)', color: '#b45309' },
                { bg: 'rgba(22,163,74,0.09)', color: '#16a34a' },
                { bg: 'rgba(220,38,38,0.08)', color: '#dc2626' },
            ];

            const catColorMap = {};
            let catIdx = 0;

            document.querySelectorAll('.mv-cat-badge').forEach(el => {
                const cat = el.dataset.cat;
                if (!catColorMap[cat]) {
                    catColorMap[cat] = catPalette[catIdx % catPalette.length];
                    catIdx++;
                }
                const c = catColorMap[cat];
                el.style.background = c.bg;
                el.style.color = c.color;
            });

            // ── Search ──
            const searchEl = document.getElementById('mvSearch');
            const bodyEl = document.getElementById('mvBody');
            const visibleEl = document.getElementById('mvVisible');

            function updateVisible() {
                let count = 0;
                bodyEl.querySelectorAll('tr').forEach(r => { if (r.style.display !== 'none') count++; });
                if (visibleEl) visibleEl.textContent = count;
            }

            searchEl?.addEventListener('input', function () {
                const q = this.value.toLowerCase().trim();
                bodyEl.querySelectorAll('tr').forEach(row => {
                    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
                });
                updateVisible();
            });

            // ── Sort ──
            let sortState = { col: null, asc: true };

            document.querySelectorAll('th.sortable').forEach(th => {
                th.addEventListener('click', function () {
                    const col = parseInt(this.dataset.col);
                    if (sortState.col === col) sortState.asc = !sortState.asc;
                    else { sortState.col = col; sortState.asc = true; }

                    const rows = Array.from(bodyEl.querySelectorAll('tr'));
                    rows.sort((a, b) => {
                        const aVal = a.cells[col]?.textContent.trim() ?? '';
                        const bVal = b.cells[col]?.textContent.trim() ?? '';
                        const aNum = parseFloat(aVal.replace(',', '.'));
                        const bNum = parseFloat(bVal.replace(',', '.'));
                        if (!isNaN(aNum) && !isNaN(bNum))
                            return sortState.asc ? aNum - bNum : bNum - aNum;
                        return sortState.asc
                            ? aVal.localeCompare(bVal, 'tr')
                            : bVal.localeCompare(aVal, 'tr');
                    });
                    rows.forEach(r => bodyEl.appendChild(r));
                });
            });
        })();
    </script>