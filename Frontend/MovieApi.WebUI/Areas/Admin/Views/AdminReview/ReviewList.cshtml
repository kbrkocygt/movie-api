@model List<ResultAdminReviewDto>
@{
    ViewData["Title"] = "Yorumlar Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --bg:         #eef0f7;
        --surface:    #ffffff;
        --surface2:   #f5f6fb;
        --border:     rgba(30,40,100,0.08);
        --border-h:   rgba(30,40,100,0.16);
        --accent:     #5b4ef8;
        --accent-dim: rgba(91,78,248,0.09);
        --accent-glow:rgba(91,78,248,0.2);
        --gold:       #b07400;
        --gold-dim:   rgba(176,116,0,0.09);
        --green:      #0a9060;
        --green-dim:  rgba(10,144,96,0.09);
        --red:        #cc3333;
        --red-dim:    rgba(204,51,51,0.08);
        --amber:      #a86000;
        --amber-dim:  rgba(168,96,0,0.09);
        --blue:       #2563eb;
        --blue-dim:   rgba(37,99,235,0.08);
        --purple:     #7c3aed;
        --purple-dim: rgba(124,58,237,0.08);
        --text:       #181830;
        --text-2:     #52527a;
        --text-3:     #9898b8;
        --radius:     10px;
        --row-h:      62px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .rv {
        font-family: 'Outfit', sans-serif;
        background: var(--bg);
        min-height: 100vh;
        padding: 1.5rem 1.5rem 3rem;
        color: var(--text);
    }

    /* ── TOP BAR ── */
    .rv-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }

    .rv-breadcrumb {
        font-size: 0.75rem;
        color: var(--text-3);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-weight: 500;
        margin-bottom: 0.2rem;
    }

    .rv-heading {
        font-size: 1.45rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: var(--text);
        line-height: 1;
    }

    .rv-pill {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        font-weight: 500;
        color: var(--accent);
        background: var(--accent-dim);
        border: 1px solid rgba(91,78,248,0.22);
        padding: 0.2rem 0.55rem;
        border-radius: 6px;
        align-self: flex-end;
        margin-bottom: 2px;
    }

    .rv-spacer { flex: 1; }
    .rv-toolbar { display: flex; align-items: center; gap: 0.6rem; }

    .rv-search { position: relative; display: flex; align-items: center; }

    .rv-search svg {
        position: absolute; left: 0.75rem;
        color: var(--text-3); width: 14px; height: 14px;
        pointer-events: none;
    }

    .rv-search input {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0.9rem 0.5rem 2.25rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.825rem;
        color: var(--text);
        width: 210px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s, width 0.25s;
    }

    .rv-search input::placeholder { color: var(--text-3); }

    .rv-search input:focus {
        border-color: rgba(91,78,248,0.4);
        box-shadow: 0 0 0 3px var(--accent-glow);
        width: 270px;
    }

    .rv-filter-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0.85rem;
        font-family: 'Outfit', sans-serif;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-2);
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
    }

    .rv-filter-btn svg { width: 13px; height: 13px; }
    .rv-filter-btn:hover { border-color: var(--border-h); color: var(--text); }

    /* ── SHELL ── */
    .rv-shell {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }

    .rv-shell::before {
        content: '';
        position: absolute;
        inset: 0 0 auto 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, var(--accent) 40%, rgba(91,78,248,0.3) 70%, transparent 100%);
        opacity: 0.5;
    }

    /* ── TABLE ── */
    .rv-table { width: 100%; border-collapse: collapse; table-layout: auto; }

    .rv-table thead th {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-3);
        padding: 0 0.75rem;
        height: 40px;
        text-align: left;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
        white-space: nowrap;
    }

    .rv-table thead th:first-child { padding-left: 1.25rem; }
    .rv-table thead th:last-child  { padding-right: 1.25rem; }

    th.sortable { cursor: pointer; user-select: none; }
    th.sortable:hover { color: var(--text-2); }
    th.sortable svg { width: 10px; height: 10px; display: inline; margin-left: 4px; vertical-align: middle; }

    /* rows */
    .rv-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
        opacity: 0;
        animation: fadeRow 0.35s ease forwards;
    }

    @@keyframes fadeRow {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .rv-table tbody tr:last-child { border-bottom: none; }
    .rv-table tbody tr:hover { background: rgba(91,78,248,0.035); }

    .rv-table tbody tr:nth-child(1)  { animation-delay: 0.03s; }
    .rv-table tbody tr:nth-child(2)  { animation-delay: 0.06s; }
    .rv-table tbody tr:nth-child(3)  { animation-delay: 0.09s; }
    .rv-table tbody tr:nth-child(4)  { animation-delay: 0.12s; }
    .rv-table tbody tr:nth-child(5)  { animation-delay: 0.15s; }
    .rv-table tbody tr:nth-child(6)  { animation-delay: 0.18s; }
    .rv-table tbody tr:nth-child(7)  { animation-delay: 0.21s; }
    .rv-table tbody tr:nth-child(8)  { animation-delay: 0.24s; }
    .rv-table tbody tr:nth-child(9)  { animation-delay: 0.27s; }
    .rv-table tbody tr:nth-child(10) { animation-delay: 0.30s; }

    .rv-table tbody td {
        padding: 0 0.75rem;
        height: var(--row-h);
        font-size: 0.875rem;
        color: var(--text);
        vertical-align: middle;
        white-space: nowrap;
    }

    .rv-table tbody td:first-child { padding-left: 1.25rem; }
    .rv-table tbody td:last-child  { padding-right: 1.25rem; }

    /* ── CELLS ── */

    .rv-id {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-3);
    }

    /* yorum metni */
    .rv-comment-cell { display: flex; flex-direction: column; gap: 0.2rem; }

    .rv-comment-text {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text);
        max-width: 260px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block;
    }

    .rv-comment-meta {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: nowrap;
    }

    /* kullanıcı chip */
    .rv-user-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.28rem;
        font-size: 0.68rem;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-dim);
        border: 1px solid rgba(91,78,248,0.15);
        padding: 0.15rem 0.5rem;
        border-radius: 5px;
        max-width: 100px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .rv-user-chip svg { width: 10px; height: 10px; flex-shrink: 0; }

    /* film id chip */
    .rv-movie-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        font-weight: 500;
        color: var(--text-3);
        background: var(--surface2);
        border: 1px solid var(--border);
        padding: 0.15rem 0.5rem;
        border-radius: 5px;
    }

    .rv-movie-chip svg { width: 10px; height: 10px; flex-shrink: 0; }

    /* kullanıcı puanı — yıldızlar */
    .rv-stars {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--gold);
        background: var(--gold-dim);
        padding: 0.22rem 0.6rem;
        border-radius: 6px;
        border: 1px solid rgba(176,116,0,0.15);
    }

    .rv-stars svg { width: 10px; height: 10px; fill: var(--gold); flex-shrink: 0; }

    /* tarih */
    .rv-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-2);
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        line-height: 1.4;
    }

    .rv-date-day { font-weight: 500; color: var(--text); }
    .rv-date-time { color: var(--text-3); }

    /* beğeni */
    .rv-likes {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--red);
        background: var(--red-dim);
        padding: 0.22rem 0.6rem;
        border-radius: 6px;
        border: 1px solid rgba(204,51,51,0.14);
    }

    .rv-likes svg { width: 11px; height: 11px; fill: var(--red); flex-shrink: 0; }

    /* sentiment skoru */
    .rv-sentiment {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .rv-sentiment-bar-bg {
        width: 56px; height: 3px;
        border-radius: 99px;
        overflow: hidden;
        background: var(--border-h);
    }

    .rv-sentiment-bar-fill {
        height: 100%;
        border-radius: 99px;
    }

    .rv-sentiment-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        font-weight: 500;
    }

    /* spoiler badge */
    .rv-spoiler {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 0.18rem 0.5rem;
        border-radius: 4px;
    }

    .rv-spoiler.yes {
        color: var(--amber);
        background: var(--amber-dim);
        border: 1px solid rgba(168,96,0,0.2);
    }

    .rv-spoiler.no {
        color: var(--text-3);
        background: var(--surface2);
        border: 1px solid var(--border);
    }

    /* durum */
    .rv-status {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 0.25rem 0.65rem;
        border-radius: 100px;
    }

    .rv-status-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    .rv-status.on  { color: var(--green); background: var(--green-dim); border: 1px solid rgba(10,144,96,0.2); }
    .rv-status.off { color: var(--red);   background: var(--red-dim);   border: 1px solid rgba(204,51,51,0.2); }

    /* ── ACTIONS ── */
    .rv-actions {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 0.25rem;
        flex-wrap: nowrap;
    }

    .rv-icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.28rem;
        height: 28px;
        padding: 0 0.6rem;
        border-radius: 7px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--text-3);
        cursor: pointer;
        text-decoration: none;
        font-family: 'Outfit', sans-serif;
        font-size: 0.73rem;
        font-weight: 500;
        white-space: nowrap;
        transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.12s;
        flex-shrink: 0;
    }

    .rv-icon-btn svg { width: 13px; height: 13px; }
    .rv-icon-btn:hover { transform: translateY(-1px); }

    .rv-icon-btn.det:hover {
        background: var(--accent-dim);
        border-color: rgba(91,78,248,0.22);
        color: var(--accent);
    }

    .rv-icon-btn.del:hover {
        background: var(--red-dim);
        border-color: rgba(204,51,51,0.2);
        color: var(--red);
    }

    /* onay butonu */
    .rv-icon-btn.approve:hover {
        background: var(--green-dim);
        border-color: rgba(10,144,96,0.22);
        color: var(--green);
    }

    .rv-actions-sep {
        width: 1px; height: 16px;
        background: var(--border);
        flex-shrink: 0;
        margin: 0 0.1rem;
    }

    /* ── FOOTER ── */
    .rv-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--surface2);
    }

    .rv-footer-info { font-size: 0.78rem; color: var(--text-3); }
    .rv-footer-info strong { color: var(--text-2); font-weight: 600; }

    /* ── EMPTY ── */
    .rv-empty { text-align: center; padding: 4rem 2rem; color: var(--text-3); }
    .rv-empty svg { width: 40px; height: 40px; margin-bottom: 0.75rem; opacity: 0.25; }
    .rv-empty p { font-size: 0.875rem; }
</style>

<div class="rv">

    <div class="rv-top">
        <div>
            <div class="rv-breadcrumb">Admin / Yorumlar</div>
            <div style="display:flex;align-items:baseline;gap:0.6rem">
                <h1 class="rv-heading">Yorum Listesi</h1>
                <span class="rv-pill">@Model.Count kayıt</span>
            </div>
        </div>

        <div class="rv-spacer"></div>

        <div class="rv-toolbar">
            <div class="rv-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input type="text" id="rvSearch" placeholder="Yorum veya kullanıcı ara…" autocomplete="off">
            </div>

            <button class="rv-filter-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="4" y1="6" x2="20" y2="6"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                    <line x1="11" y1="18" x2="13" y2="18"/>
                </svg>
                Filtrele
            </button>
        </div>
    </div>

    <div class="rv-shell">
        <div style="overflow-x:auto">
            <table class="rv-table" id="rvTable">
                <thead>
                    <tr>
                        <th style="width:44px">#</th>
                        <th style="min-width:240px">Yorum</th>
                        <th class="sortable" data-col="2" style="width:90px">
                            Puan
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5"/><path d="M7 9l5-5 5 5"/></svg>
                        </th>
                        <th class="sortable" data-col="3" style="width:105px">
                            Tarih
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5"/><path d="M7 9l5-5 5 5"/></svg>
                        </th>
                        <th class="sortable" data-col="4" style="width:80px">
                            Beğeni
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 15l5 5 5-5"/><path d="M7 9l5-5 5 5"/></svg>
                        </th>
                        <th style="width:90px">Duygu</th>
                        <th style="width:80px">Spoiler</th>
                        <th style="width:88px">Durum</th>
                        <th style="width:160px">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="rvBody">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        count++;

                        // sentiment rengi
                        string sentColor = "#9898b8";
                        string sentBg = "rgba(152,152,184,0.12)";
                        string sentLabel = "—";
                        if (item.SentimentScore.HasValue)
                        {
                            double s = (double)item.SentimentScore.Value;
                            sentLabel = s.ToString("F2");
                            if (s >= 0.6)      { sentColor = "#0a9060"; sentBg = "rgba(10,144,96,0.12)"; }
                            else if (s >= 0.4) { sentColor = "#b07400"; sentBg = "rgba(176,116,0,0.12)"; }
                            else               { sentColor = "#cc3333"; sentBg = "rgba(204,51,51,0.1)"; }
                        }

                        <tr>
                            <td><span class="rv-id">@count</span></td>

                            <!-- Yorum + kullanıcı + film -->
                            <td>
                                <div class="rv-comment-cell">
                                    <span class="rv-comment-text" title="@item.ReviewComment">@item.ReviewComment</span>
                                    <div class="rv-comment-meta">
                                        <span class="rv-user-chip">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                                <circle cx="12" cy="7" r="4"/>
                                            </svg>
                                            @item.UserId
                                        </span>
                                        <span class="rv-movie-chip">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                                <path d="M10 9l5 3-5 3V9z"/>
                                            </svg>
                                            #@item.MovieId
                                        </span>
                                    </div>
                                </div>
                            </td>

                            <!-- Kullanıcı puanı -->
                            <td>
                                <span class="rv-stars">
                                    <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                    @item.UserRating
                                </span>
                            </td>

                            <!-- Tarih -->
                            <td>
                                <div class="rv-date">
                                    <span class="rv-date-day">@item.ReviewDate.ToString("dd MMM yyyy")</span>
                                    <span class="rv-date-time">@item.ReviewDate.ToString("HH:mm")</span>
                                </div>
                            </td>

                            <!-- Beğeni -->
                            <td>
                                <span class="rv-likes">
                                    <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                    @item.LikeCount
                                </span>
                            </td>

                            <!-- Duygu skoru -->
                            <td>
                                <div class="rv-sentiment">
                                    <span class="rv-sentiment-val" style="color:@sentColor">@sentLabel</span>
                                    @if (item.SentimentScore.HasValue)
                                    {
                                        <div class="rv-sentiment-bar-bg">
                                            <div class="rv-sentiment-bar-fill"
                                                 style="width:@(((double)item.SentimentScore.Value * 100).ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%;background:@sentColor"></div>
                                        </div>
                                    }
                                </div>
                            </td>

                            <!-- Spoiler -->
                            <td>
                                @if (item.IsSpoiler)
                                {
                                    <span class="rv-spoiler yes">
                                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                        Spoiler
                                    </span>
                                }
                                else
                                {
                                    <span class="rv-spoiler no">Temiz</span>
                                }
                            </td>

                            <!-- Durum -->
                            <td>
                                @if (item.Status)
                                {
                                    <span class="rv-status on"><span class="rv-status-dot"></span>Aktif</span>
                                }
                                else
                                {
                                    <span class="rv-status off"><span class="rv-status-dot"></span>Pasif</span>
                                }
                            </td>

                            <!-- İşlemler -->
                            <td>
                                <div class="rv-actions">
                                    <a href="#" class="rv-icon-btn det">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                        Detay
                                    </a>
                                    <span class="rv-actions-sep"></span>
                                    <a href="#" class="rv-icon-btn del">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14H6L5 6"/>
                                            <path d="M10 11v6M14 11v6"/>
                                            <path d="M9 6V4h6v2"/>
                                        </svg>
                                        Sil
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9">
                            <div class="rv-empty">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                </svg>
                                <p>Henüz yorum eklenmemiş.</p>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="rv-footer">
            <span class="rv-footer-info">
                Toplam <strong>@Model.Count</strong> yorum &nbsp;·&nbsp;
                <span id="rvVisible">@Model.Count</span> gösteriliyor
            </span>
        </div>
    </div>
</div>

<script>
(function () {
    // ── Search ──
    const searchEl  = document.getElementById('rvSearch');
    const bodyEl    = document.getElementById('rvBody');
    const visibleEl = document.getElementById('rvVisible');

    function updateVisible() {
        let count = 0;
        bodyEl.querySelectorAll('tr').forEach(r => { if (r.style.display !== 'none') count++; });
        if (visibleEl) visibleEl.textContent = count;
    }

    searchEl?.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        bodyEl.querySelectorAll('tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
        updateVisible();
    });

    // ── Sort ──
    let sortState = { col: null, asc: true };

    document.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', function () {
            const col = parseInt(this.dataset.col);
            if (sortState.col === col) sortState.asc = !sortState.asc;
            else { sortState.col = col; sortState.asc = true; }

            const rows = Array.from(bodyEl.querySelectorAll('tr'));
            rows.sort((a, b) => {
                const aVal = a.cells[col]?.textContent.trim() ?? '';
                const bVal = b.cells[col]?.textContent.trim() ?? '';
                const aNum = parseFloat(aVal.replace(',', '.'));
                const bNum = parseFloat(bVal.replace(',', '.'));
                if (!isNaN(aNum) && !isNaN(bNum))
                    return sortState.asc ? aNum - bNum : bNum - aNum;
                return sortState.asc
                    ? aVal.localeCompare(bVal, 'tr')
                    : bVal.localeCompare(aVal, 'tr');
            });
            rows.forEach(r => bodyEl.appendChild(r));
        });
    });
})();
</script>
